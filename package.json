    "i18next": "^24.2.2",
    "i18next-browser-languagedetector": "^8.0.2",
    "i18next-http-backend": "^3.0.2",
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^3.0.0",
    "react-hook-form": "^7.54.2",
    "react-i18next": "^15.2.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.1.1",
    "sonner": "^1.7.2",
