# =============================================
# Git Ignore - Immobilier Frontend
# =============================================

# Dependencies
node_modules
.pnp
.pnp.js

# Build output
dist
dist-ssr
build
*.local

# Environment files (keep .example)
.env
.env.local
.env.*.local
!.env.example

# Logs
logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor directories and files
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*~

# Testing
coverage
*.lcov

# TypeScript
*.tsbuildinfo

# Vite
.vite

# Misc
.eslintcache
.stylelintcache
*.pem

# Production secrets (use .env.production.example as template)
.env.production
