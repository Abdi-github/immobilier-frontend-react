# =============================================
# Environment Variables - Immobilier Frontend
# Copy this file to .env.development or .env.production
# =============================================

# API Configuration (REQUIRED)
VITE_API_BASE_URL=http://localhost:4003/api/v1

# App Configuration
VITE_APP_NAME=Immobilier.ch
VITE_APP_VERSION=1.0.0
VITE_DEFAULT_LANGUAGE=en

# Supported Languages
VITE_SUPPORTED_LANGUAGES=en,fr,de,it

# Feature Flags
VITE_ENABLE_DEV_TOOLS=true
VITE_ENABLE_MOCK_API=false

# Cloudinary (for image transformations on client-side if needed)
VITE_CLOUDINARY_CLOUD_NAME=dzyyygr1x

# Contact Information
VITE_CONTACT_EMAIL=contact@immobilier.ch
VITE_CONTACT_PHONE=+41 21 123 45 67
